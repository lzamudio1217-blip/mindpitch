# MindPitch Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase public browser values
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Anthropic API Key — server-side only for /api/chat
# Do not prefix this with REACT_APP_
ANTHROPIC_API_KEY=sk-ant-your-key-here
